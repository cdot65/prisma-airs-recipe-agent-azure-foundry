# Azure AI Foundry project + agent
# Endpoint format: https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_AI_AGENT_NAME=your-agent-name
AZURE_AI_AGENT_VERSION=1

# Azure service principal credentials (DefaultAzureCredential -> EnvironmentCredential)
# Mint with: az ad sp create-for-rbac --name "<sp-name>" --role "Azure AI User" \
#   --scopes "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>"
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=

# Prisma AIRS
PANW_AI_SEC_API_KEY=
PANW_AI_SEC_API_ENDPOINT=https://service.api.aisecurity.paloaltonetworks.com
PANW_AI_SEC_PROFILE_NAME=your-airs-profile-name

# Optional: override the default user prompt at runtime
# AGENT_PROMPT=How do I make a classic French baguette at home?
